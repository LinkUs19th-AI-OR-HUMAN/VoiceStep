APP_ENV=development
APP_NAME=AI Conversation Training MVP
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL connection. Supabase example:
# postgresql+psycopg2://postgres:password@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/ai_training

# Gemini Flash (free tier). Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_firebase_project_id
# Paste the entire service-account JSON on a single line.
# Example: {"type":"service_account","project_id":"...", ...}
FIREBASE_SERVICE_ACCOUNT_JSON=

# STT
# STT engine: "groq_whisper" (API, recommended) or "faster_whisper" (local)
STT_ENGINE=groq_whisper

# Groq Whisper API (Get key at https://console.groq.com/keys)
GROQ_API_KEY=

# faster-whisper local model (used only when STT_ENGINE=faster_whisper)
WHISPER_MODEL_SIZE=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

MAX_CONVERSATION_TURNS=5

# Local development: bypass Firebase token check (DO NOT enable in production).
DEV_AUTH_BYPASS=false
